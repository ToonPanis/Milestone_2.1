<%- include("partials/header") %>

<section class="page-title-section">
    <h2 class="page-title">Alle reizen</h2>
    <p class="page-subtitle">Bekijk alle rezien die je hebt gepland </p>
</section>

<div class="journeys-container">
    <% for (let journey of journeys) { %>
        <a href="/journey/<%= journey.id %>" class="journey-card">
            <img src="<%= journey.img %>" alt="Image of <%= journey.city %>">
            <h2><%= journey.country %> - <%= journey.city %></h2>
            <p><strong>Startdatum:</strong> <%= journey.startDate %></p>
            <p><strong>Duur (dagen):</strong> <%= journey.duration %></p>
            <p><strong>Prijs (€):</strong> <%= journey.price %></p>
            <p><strong>Status:</strong> <%= journey.status %></p>
            <p><strong>Betaald:</strong> <%= journey.paid %></p>
        </a>
    <% } %>
</div>

<%- include("partials/footer") %>
