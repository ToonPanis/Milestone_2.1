<%- include("partials/header") %>

<section class="page-title-section">
    <h2 class="page-title">Alle accommodaties</h2>
    <p class="page-subtitle">Bekijk alle verblijven die je hebt gepland</p>
</section>

<div class="accommodations-container">
    <% journeys.forEach(journey => { %>
        <div class="accommodation-card">
            <a href="/journey/<%= journey.id %>/accommodation">
                <img src="<%= journey.img %>" alt="Image of <%= journey.accommodation.name %>" class="accommodation-img">
                <h2><%= journey.accommodation.name %></h2>
                <p><strong>Adres:</strong> <%= journey.accommodation.adress %></p>
                <p><strong>Rank:</strong> <%= journey.accommodation.rank %></p>
            </a>
        </div>
    <% }) %>
</div>

<%- include("partials/footer") %>
