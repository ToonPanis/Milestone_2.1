<%- include("partials/header") %>

<main class="main-content">
    <section class="page-title-section">
        <h2 class="page-title">Geplande reizen</h2>
        <p class="page-subtitle">Bekijk en sorteer al je reizen</p>
    </section>

    <section class="sort-section">
        <form action="/" method="get" class="sort-form">
            <div class="sort-field">
                <label for="sortField">Sorteer op</label>
                <select name="sortField" id="sortField">
                    <% for (let field of sortFields) { %>
                        <option value="<%= field.value %>" <%= field.selected %>>
                            <%= field.text %>
                        </option>
                    <% } %>
                </select>
            </div>

            <div class="sort-field">
                <label for="sortDirection">Volgorde</label>
                <select name="sortDirection" id="sortDirection">
                    <% for (let direction of sortDirections) { %>
                        <option value="<%= direction.value %>" <%= direction.selected %>>
                            <%= direction.text %>
                        </option>
                    <% } %>
                </select>
            </div>

            <div class="sort-button-wrap">
                <button type="submit">Sorteren</button>
            </div>
        </form>
    </section>

    <section class="table-section">
        <table>
            <thead>
                <tr>
                    <th>Land</th>
                    <th>Stad</th>
                    <th>Startdatum</th>
                    <th>Duur (dagen)</th>
                    <th>Prijs (€)</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <% for (let journey of journeys) { %>
                    <tr>
                        <td><a href="/journey/<%= journey.id %>"><%= journey.country %></a></td>
                        <td><a href="/journey/<%= journey.id %>"><%= journey.city %></a></td>
                        <td><%= journey.startDate %></td>
                        <td><%= journey.duration %></td>
                        <td><%= journey.price %></td>
                        <td><%= journey.status %></td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </section>
</main>

<%- include("partials/footer") %>